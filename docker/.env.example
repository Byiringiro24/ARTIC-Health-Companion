# ─── ARTIC Health Companion — Docker environment variables ───────────────────
# Copy this file to .env and fill in production values before running
# docker compose up -d

# ── HMS App ───────────────────────────────────────────────────────────────────
NODE_ENV=production

# ── Backend ───────────────────────────────────────────────────────────────────
# SQLite (default, no postgres needed) — HMS will use SQLite file in /app/data
# To use PostgreSQL instead, uncomment HMS_DATABASE_URL below
# HMS_DATABASE_URL=postgresql://artic_hms_user:STRONG_PASSWORD@host.docker.internal:5432/artic_hms?schema=public&sslmode=disable

# JWT secrets — generate with: openssl rand -hex 32
HMS_JWT_ACCESS_SECRET=REPLACE_WITH_64_CHAR_RANDOM_STRING_A
HMS_JWT_REFRESH_SECRET=REPLACE_WITH_64_CHAR_RANDOM_STRING_B

# CORS — frontend URL
HMS_CORS_ORIGIN=https://hms.yourcompany.rw,http://YOUR_SERVER_IP:3001

# Redis (shared with VMS project, different key prefix)
REDIS_URL=redis://host.docker.internal:6379

# ── Frontend ──────────────────────────────────────────────────────────────────
# API URL that the browser will call (must be publicly reachable)
HMS_API_URL=https://hms.yourcompany.rw/api
# OR use IP directly if no domain yet:
# HMS_API_URL=http://YOUR_SERVER_IP:4001

# ── Facility ──────────────────────────────────────────────────────────────────
DEFAULT_FACILITY=Kigali District Hospital
