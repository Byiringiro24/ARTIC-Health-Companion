# ─── ARTIC HMS — PRODUCTION SERVER ENV ────────────────────────────────────────
# Server: 172.209.217.176  (artic@Artic)
# HMS runs on ports 4001 (backend) + 3001 (frontend)
# PostgreSQL HMS: Docker container artic-hms-postgres → host port 5433
# Redis HMS:      Docker container artic-hms-redis    → host port 6380
# VMS project untouched on ports 4000/3000

PORT=4001
NODE_ENV=production

# ─── Database ─────────────────────────────────────────────────────────────────
# Note: password is the literal string "Artic%242026" (Docker was started with this)
DATABASE_URL=postgresql://Byiringiro:Artic%25242026@localhost:5433/artic_hms?sslmode=disable

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
JWT_ACCESS_SECRET=artic-production-jwt-secret-min-32-chars-2026
JWT_REFRESH_SECRET=artic-production-refresh-secret-2026
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d
BCRYPT_ROUNDS=12

# ─── CORS ─────────────────────────────────────────────────────────────────────
CORS_ORIGIN=http://172.209.217.176:3001,http://localhost:3001

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6380
REDIS_PREFIX=hms:

# ─── Rate Limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=200
AUTH_RATE_LIMIT_MAX=10

# ─── Facility ─────────────────────────────────────────────────────────────────
DEFAULT_FACILITY=Kigali District Hospital
DEFAULT_TIMEZONE=Africa/Kigali
DEFAULT_CURRENCY=RWF
FRONTEND_URL=http://172.209.217.176:3001

# ─── Email ───────────────────────────────────────────────────────────────────
# Gmail account: articltd1@gmail.com
# NOTE: Gmail SMTP requires an App Password (16 chars), NOT the regular password.
# The regular password below will trigger EAUTH error.
# To fix: go to myaccount.google.com/apppasswords → generate → paste below
# Full guide: docs/EMAIL-SETUP.md
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=articltd1@gmail.com
SMTP_PASS=gfazkoxoxddpxjyl
EMAIL_FROM=ARTIC Health Companion <articltd1@gmail.com>
EMAIL_FROM_NAME=ARTIC Health Companion
EMAIL_FROM_ADDRESS=articltd1@gmail.com

# ─── SMS - Africa's Talking (fill in for production) ─────────────────────────
AT_API_KEY=
AT_USERNAME=sandbox
AT_SENDER=

# ─── OpenAI (fill in when ready) ─────────────────────────────────────────────
OPENAI_API_KEY=
